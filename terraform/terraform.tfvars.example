# Terraform Variables Example
# Copy this file to terraform.tfvars and update with your values

# Project Configuration
project_name = "ionic-boilerplate"
environment = "dev"
aws_region = "us-east-1"
domain_name = "yourapp.com"

# DNS Configuration
create_route53_zone = false
use_cloudflare = false
cloudflare_api_token = ""
cloudflare_zone_id = ""

# Database Configuration
db_instance_class = "db.t3.micro"
db_name = "ionicboilerplate"
db_username = "admin"
db_password = "your-secure-password-here"
db_allocated_storage = 20
db_max_allocated_storage = 100
db_backup_retention_period = 7
db_backup_window = "03:00-04:00"
db_maintenance_window = "sun:04:00-sun:05:00"

# Redis Configuration
redis_node_type = "cache.t3.micro"
redis_num_cache_nodes = 1
redis_port = 6379

# ECS Configuration
ecs_cluster_name = "ionic-boilerplate-cluster"
ecs_task_cpu = 256
ecs_task_memory = 512
ecs_desired_count = 1
ecs_min_capacity = 1
ecs_max_capacity = 10
ecs_target_cpu_utilization = 70

# Application Configuration
app_port = 4200
app_health_check_path = "/health"
app_health_check_interval = 30
app_health_check_timeout = 5
app_health_check_healthy_threshold = 2
app_health_check_unhealthy_threshold = 3

# SSL/TLS Configuration
ssl_certificate_arn = ""
enable_ssl = true

# Logging and Monitoring
enable_cloudwatch_logs = true
log_retention_days = 14
enable_xray_tracing = false

# Security Configuration
enable_ddos_protection = false
enable_waf = false
allowed_cidr_blocks = ["0.0.0.0/0"]

# Cost and Budget
cost_allocation_tag = "ionic-boilerplate"
enable_cost_monitoring = true
monthly_budget_amount = 100
budget_notification_emails = ["alerts@yourapp.com"]
alert_email = "alerts@yourapp.com"

# Feature Flags
enable_api_gateway = true
enable_database = true
enable_redis = true
enable_s3_static_hosting = true
enable_cloudfront = true
enable_autoscaling = true

# VPC Configuration
vpc_cidr = "10.0.0.0/16"
public_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24", "10.0.13.0/24"]
availability_zones = ["us-east-1a", "us-east-1b", "us-east-1c"]

# Environment-specific configurations (these will override the above based on environment)
dev_config = {
  db_instance_class = "db.t3.micro"
  ecs_desired_count = 1
  enable_ssl = false
  monthly_budget_amount = 50
}

staging_config = {
  db_instance_class = "db.t3.small"
  ecs_desired_count = 2
  enable_ssl = true
  monthly_budget_amount = 200
}

prod_config = {
  db_instance_class = "db.t3.medium"
  ecs_desired_count = 3
  enable_ssl = true
  monthly_budget_amount = 1000
}
